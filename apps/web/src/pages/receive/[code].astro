---
import JoinSessionPanel from "../../components/JoinSessionPanel.vue";
import AppLayout from "../../layouts/AppLayout.astro";

export const prerender = false;

const code = Astro.params.code ?? "unknown";
---

<AppLayout
  title={`Receive ${code} | Bore v2`}
  description="Load and join a Bore v2 transfer session from the browser."
>
  <JoinSessionPanel client:load code={code} />
</AppLayout>
