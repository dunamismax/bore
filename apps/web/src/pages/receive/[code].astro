---
import ReceiveTransferPanel from "../../components/ReceiveTransferPanel.vue";
import AppLayout from "../../layouts/AppLayout.astro";

export const prerender = false;

const code = Astro.params.code ?? "unknown";
---

<AppLayout
  title={`Receive ${code} | Bore v2`}
  description="Receive an encrypted file through the Bore v2 relay."
>
  <ReceiveTransferPanel client:load code={code} />
</AppLayout>
