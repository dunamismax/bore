---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Bore Relay Ops | Live relay status"
  description="Operator-facing status page for the Bore relay. Reads aggregate service data from the relay /status endpoint."
>
  <section class="ops-hero panel">
    <div>
      <p class="eyebrow">Operator-facing surface</p>
      <h1>Relay status, without pretending it is a control plane.</h1>
      <p class="hero-body">
        This page reads aggregate service data from the current relay at <code>/status</code>.
        It is same-origin, read-only, and scoped to uptime, room counts, and configured relay
        limits.
      </p>
    </div>
    <div class="ops-note">
      <p class="section-kicker">Current scope</p>
      <p>No auth. No file inspection. No direct transport claims. No hidden backend.</p>
    </div>
  </section>

  <section class="panel status-panel" x-data="relayStatusPanel" x-init="init()">
    <script>
      import "../../../scripts/relay-status";
    </script>

    <div class="status-toolbar">
      <div>
        <p class="section-kicker">Live snapshot</p>
        <h2>Relay status</h2>
      </div>
      <div class="toolbar-actions">
        <label class="toggle">
          <input type="checkbox" x-model="autoRefresh" x-on:change="syncAutoRefresh()" />
          <span>Auto-refresh every 5s</span>
        </label>
        <button class="button button-secondary" type="button" x-on:click="refresh()" x-bind:disabled="refreshing">
          <span x-show="!refreshing">Refresh now</span>
          <span x-show="refreshing">Refreshing...</span>
        </button>
      </div>
    </div>

    <div class="status-meta">
      <p x-show="lastUpdated">Last updated: <strong x-text="lastUpdated"></strong></p>
      <p x-show="loading">Loading current relay state...</p>
      <p class="status-error" x-show="error">Status fetch failed: <span x-text="error"></span></p>
    </div>

    <div class="metric-grid" x-cloak x-show="relay">
      <article class="metric-card">
        <p class="metric-label">Service</p>
        <p class="metric-value" x-text="relay?.service"></p>
        <p class="metric-note">Current relay identity from <code>/status</code>.</p>
      </article>
      <article class="metric-card">
        <p class="metric-label">Status</p>
        <p class="metric-value" x-text="relay?.status"></p>
        <p class="metric-note">Expected steady state is <code>ok</code>.</p>
      </article>
      <article class="metric-card">
        <p class="metric-label">Uptime</p>
        <p class="metric-value" x-text="relay ? uptime(relay.uptimeSeconds) : '0s'"></p>
        <p class="metric-note">Process uptime reported by the relay.</p>
      </article>
      <article class="metric-card">
        <p class="metric-label">Max WebSocket message</p>
        <p class="metric-value" x-text="relay ? bytes(relay.limits.maxMessageSizeBytes) : '0 B'"></p>
        <p class="metric-note">Per-message transport cap enforced by the relay.</p>
      </article>
    </div>

    <div class="room-panels" x-cloak x-show="relay">
      <article class="room-card">
        <div class="room-card-head">
          <div>
            <p class="metric-label">Waiting rooms</p>
            <p class="room-value" x-text="relay?.rooms.waiting"></p>
          </div>
          <p class="room-share" x-text="roomFill(relay?.rooms.waiting ?? 0)"></p>
        </div>
        <div class="room-meter">
          <span class="room-meter-fill" x-bind:style="`width: ${roomFill(relay?.rooms.waiting ?? 0)}`"></span>
        </div>
      </article>

      <article class="room-card">
        <div class="room-card-head">
          <div>
            <p class="metric-label">Active rooms</p>
            <p class="room-value" x-text="relay?.rooms.active"></p>
          </div>
          <p class="room-share" x-text="roomFill(relay?.rooms.active ?? 0)"></p>
        </div>
        <div class="room-meter">
          <span class="room-meter-fill room-meter-fill-active" x-bind:style="`width: ${roomFill(relay?.rooms.active ?? 0)}`"></span>
        </div>
      </article>

      <article class="room-card">
        <div class="room-card-head">
          <div>
            <p class="metric-label">Total rooms tracked</p>
            <p class="room-value" x-text="relay?.rooms.total"></p>
          </div>
          <p class="room-share" x-text="relay?.limits.maxRooms"></p>
        </div>
        <div class="room-meter">
          <span class="room-meter-fill room-meter-fill-total" x-bind:style="`width: ${roomFill(relay?.rooms.total ?? 0)}`"></span>
        </div>
      </article>
    </div>

    <div class="limit-grid" x-cloak x-show="relay">
      <article class="limit-card">
        <p class="metric-label">Room TTL</p>
        <p class="metric-value" x-text="relay ? uptime(relay.limits.roomTTLSeconds) : '0s'"></p>
      </article>
      <article class="limit-card">
        <p class="metric-label">Reap interval</p>
        <p class="metric-value" x-text="relay ? uptime(relay.limits.reapIntervalSeconds) : '0s'"></p>
      </article>
      <article class="limit-card">
        <p class="metric-label">Room cap</p>
        <p class="metric-value" x-text="relay?.limits.maxRooms"></p>
      </article>
    </div>

    <details class="raw-status" x-cloak x-show="rawStatus">
      <summary>Raw <code>/status</code> payload</summary>
      <pre x-text="rawStatus"></pre>
    </details>
  </section>
</BaseLayout>
